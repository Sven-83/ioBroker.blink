{
  "type": "panel",
  "items": {
    "_authHeader": {
      "type": "header",
      "text": "Blink Account",
      "size": 3
    },
    "email": {
      "type": "text",
      "label": "Email address",
      "sm": 12,
      "md": 6,
      "validators": ["email"]
    },
    "password": {
      "type": "password",
      "label": "Password",
      "sm": 12,
      "md": 6
    },
    "_pollHeader": {
      "type": "header",
      "text": "Polling",
      "size": 3
    },
    "pollingInterval": {
      "type": "number",
      "label": "Polling interval (seconds)",
      "min": 10,
      "max": 3600,
      "default": 30,
      "sm": 12,
      "md": 6
    },
    "_infoHeader": {
      "type": "header",
      "text": "2FA Information",
      "size": 3
    },
    "_2faInfo": {
      "type": "staticText",
      "text": "If Blink requires two-factor authentication, the adapter will log a warning. Send the SMS PIN via ioBroker script: sendTo('blink.0', 'verifyPin', {pin: '123456'})",
      "sm": 12
    }
  }
}
