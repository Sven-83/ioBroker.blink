{
  "common": {
    "name": "blink",
    "version": "1.0.0",
    "title": "Blink Camera",
    "titleLang": {
      "en": "Blink Camera",
      "de": "Blink Kamera"
    },
    "desc": {
      "en": "Control and monitor Blink cameras: live snapshots, battery, temperature, arm/disarm",
      "de": "Blink-Kameras steuern und überwachen: Live-Snapshots, Batterie, Temperatur, Scharf-/Unscharf-Schaltung"
    },
    "authors": ["Sven"],
    "keywords": ["blink", "camera", "security", "snapshot"],
    "license": "MIT",
    "platform": "Javascript/Node.js",
    "main": "main.js",
    "icon": "https://raw.githubusercontent.com/Sven-83/iobroker.blink/main/admin/blink.png",
"extIcon": "https://raw.githubusercontent.com/Sven-83/iobroker.blink/main/admin/blink.png",
    "enabled": true,
    "loglevel": "info",
    "mode": "daemon",
    "type": "camera",
    "messagebox": true,
    "news": {
      "1.0.0": {
        "en": "Initial release",
        "de": "Erstveröffentlichung"
      }
    },
    "adminUI": {
      "config": "json"
    }
  },
  "native": {
    "email": "",
    "password": "",
    "pin": "",
    "pollingInterval": 30,
    "snapshotPollingInterval": 60,
    "saveSnapshots": true,
    "snapshotPath": ""
  },
  "objects": [],
  "instanceObjects": [
    {
      "_id": "info",
      "type": "channel",
      "common": {
        "name": "Information"
      },
      "native": {}
    },
    {
      "_id": "info.connection",
      "type": "state",
      "common": {
        "name": "Connected to Blink",
        "type": "boolean",
        "role": "indicator.connected",
        "read": true,
        "write": false,
        "def": false
      },
      "native": {}
    }
  ]
}
